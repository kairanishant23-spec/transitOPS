generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ─── Users ────────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         String   @default("Driver") // Fleet Manager | Driver | Safety Officer | Financial Analyst
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

// ─── Vehicles ─────────────────────────────────────────
model Vehicle {
  id                 String   @id @default(cuid())
  registrationNumber String   @unique @map("registration_number")
  model              String
  type               String   // Van | Truck | Trailer
  capacity           Float    @default(0) // max load in kg
  odometer           Float    @default(0)
  acquisitionCost    Float    @default(0) @map("acquisition_cost")
  status             String   @default("Available") // Available | On Trip | In Shop | Retired
  imageUrl           String?  @map("image_url")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  trips            Trip[]
  maintenanceLogs  MaintenanceLog[]
  fuelLogs         FuelLog[]
  expenses         Expense[]

  @@map("vehicles")
}

// ─── Drivers ──────────────────────────────────────────
model Driver {
  id              String   @id @default(cuid())
  name            String
  licenseNumber   String   @unique @map("license_number")
  licenseCategory String   @default("Standard") @map("license_category")
  licenseExpiry   DateTime @map("license_expiry")
  phone           String?
  safetyScore     Int      @default(100) @map("safety_score")
  status          String   @default("Available") // Available | On Trip | Off Duty | Suspended
  imageUrl        String?  @map("image_url")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  trips Trip[]

  @@map("drivers")
}

// ─── Trips ────────────────────────────────────────────
model Trip {
  id           String   @id @default(cuid())
  vehicleId    String   @map("vehicle_id")
  driverId     String   @map("driver_id")
  source       String
  destination  String
  cargoWeight  Float    @default(0) @map("cargo_weight")
  distance     Float    @default(0)
  status       String   @default("Draft") // Draft | Dispatched | Completed | Cancelled
  revenue      Float    @default(0)
  fuelConsumed Float    @default(0) @map("fuel_consumed")
  endOdometer  Float?   @map("end_odometer")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  driver  Driver  @relation(fields: [driverId], references: [id])

  @@map("trips")
}

// ─── Maintenance Logs ─────────────────────────────────
model MaintenanceLog {
  id          String   @id @default(cuid())
  vehicleId   String   @map("vehicle_id")
  description String
  cost        Float    @default(0)
  date        DateTime @default(now())
  status      String   @default("Open") // Open | Closed
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@map("maintenance_logs")
}

// ─── Fuel Logs ────────────────────────────────────────
model FuelLog {
  id        String   @id @default(cuid())
  vehicleId String   @map("vehicle_id")
  litres    Float
  cost      Float
  distance  Float    @default(0)
  date      DateTime @default(now())
  createdAt DateTime @default(now()) @map("created_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@map("fuel_logs")
}

// ─── Expenses ─────────────────────────────────────────
model Expense {
  id        String   @id @default(cuid())
  vehicleId String   @map("vehicle_id")
  category  String   // Fuel | Toll | Maintenance | Insurance | Other
  amount    Float
  date      DateTime @default(now())
  createdAt DateTime @default(now()) @map("created_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@map("expenses")
}
